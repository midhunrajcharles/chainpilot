{
  "name": "chainpilot-backend",
  "version": "1.0.0",
  "description": "ChainPilot AI Backend API - AI-powered crypto swap dApp",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "agent": "cd src/agent && bun run start",
    "agent:dev": "cd src/agent && bun run dev"
  },
  "keywords": [
    "blockchain",
    "crypto",
    "ai",
    "somnia",
    "hackathon"
  ],
  "author": "ChainPilot AI Team",
  "license": "MIT",
  "dependencies": {
    "@ai16z/eliza": "0.1.6",
    "@ai16z/plugin-evm": "0.1.6",
    "openai": "4.104.0",
    "langchain": "0.3.6",
    "@langchain/core": "0.3.80",
    "@langchain/openai": "0.3.16",
    "ethers": "^6.14.0",
    "zod": "3.23.8",
    "axios": "1.7.9",
    "cloudinary": "2.5.1",
    "compression": "1.8.0",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "express-validator": "7.2.0",
    "helmet": "8.0.0",
    "mongoose": "8.9.5",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "node-cron": "3.0.3",
    "nodemailer": "6.10.1",
    "pdfkit": "0.15.1",
    "qrcode": "1.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "hardhat": "2.28.0",
    "@nomicfoundation/hardhat-toolbox": "6.1.0",
    "@types/compression": "1.7.5",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/morgan": "1.9.9",
    "@types/multer": "1.4.12",
    "@types/node": "22.13.5",
    "@types/node-cron": "3.0.11",
    "@types/nodemailer": "6.4.17",
    "@types/pdfkit": "0.13.9",
    "@types/qrcode": "1.5.5",
    "nodemon": "3.1.9",
    "ts-node-dev": "2.0.0"
  }
}
